#usda 1.0
(
    defaultPrim = "World"
    upAxis = "Y"
    metersPerUnit = 1
)

def Xform "World"
{
    # SphereLight with ShadowAPI + ShapingAPI applied (cone + IES + shadow tint).
    def SphereLight "Spot" (
        prepend apiSchemas = ["ShadowAPI", "ShapingAPI"]
    )
    {
        color3f inputs:color = (1, 0.8, 0.6)
        float inputs:intensity = 25
        float inputs:radius = 0.1
        bool inputs:normalize = 1
        float inputs:diffuse = 1.0
        float inputs:specular = 0.7
        float inputs:colorTemperature = 4500
        bool inputs:enableColorTemperature = 1

        # ShadowAPI
        bool inputs:shadow:enable = 1
        color3f inputs:shadow:color = (0.05, 0.05, 0.1)
        float inputs:shadow:distance = 50
        float inputs:shadow:falloff = 2
        float inputs:shadow:falloffGamma = 1.5

        # ShapingAPI
        float inputs:shaping:cone:angle = 22.5
        float inputs:shaping:cone:softness = 0.25
        float inputs:shaping:focus = 4
        color3f inputs:shaping:focusTint = (0.1, 0.1, 0.1)
        asset inputs:shaping:ies:file = @profiles/spot.ies@
        float inputs:shaping:ies:angleScale = 1.1
        bool inputs:shaping:ies:normalize = 1
    }

    # RectLight with texture file.
    def RectLight "Panel"
    {
        color3f inputs:color = (1, 1, 1)
        float inputs:intensity = 8
        float inputs:width = 2.5
        float inputs:height = 1.0
        asset inputs:texture:file = @textures/softbox.exr@
    }

    # GeometryLight bound to a Mesh.
    def Mesh "Bulb"
    {
        point3f[] points = [(-0.5, 0, -0.5), (0.5, 0, -0.5), (0.5, 0, 0.5), (-0.5, 0, 0.5)]
        int[] faceVertexCounts = [4]
        int[] faceVertexIndices = [0, 1, 2, 3]
    }

    def GeometryLight "GeoLit"
    {
        color3f inputs:color = (1, 0.7, 0.3)
        float inputs:intensity = 6
        rel geometry = </World/Bulb>
    }

    # DomeLight with portal, format, guideRadius.
    def DomeLight "Sky"
    {
        color3f inputs:color = (1, 1, 1)
        float inputs:intensity = 1
        asset inputs:texture:file = @hdri/sky.exr@
        token inputs:texture:format = "latlong"
        float guideRadius = 100
        rel portals = </World/Window>
    }

    def PortalLight "Window"
    {
        float3[] extent = [(-1, -2, 0), (1, 2, 0)]
    }
}

