#usda 1.0
(
    defaultPrim = "World"
    upAxis = "Y"
    metersPerUnit = 1
)

def Xform "World"
{
    def Camera "MainCam"
    {
        token projection = "perspective"
        float horizontalAperture = 36
        float verticalAperture = 24
        float focalLength = 50
        float2 clippingRange = (0.5, 250)
        float focusDistance = 5
        float fStop = 2.8
        double3 xformOp:translate = (0, 1.6, 5)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def DistantLight "Sun"
    {
        color3f inputs:color = (1, 0.95, 0.9)
        float inputs:intensity = 3
        float inputs:exposure = 0.5
        float inputs:angle = 0.53
        double3 xformOp:rotateXYZ = (-45, 30, 0)
        uniform token[] xformOpOrder = ["xformOp:rotateXYZ"]
    }

    def SphereLight "Bulb"
    {
        color3f inputs:color = (0.4, 0.6, 1)
        float inputs:intensity = 12
        float inputs:radius = 0.25
        double3 xformOp:translate = (-2, 2, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
}

